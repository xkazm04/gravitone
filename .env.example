# Copy to .env (gitignored) and fill in. service/config.py loads this file
# at startup; real environment variables take precedence over .env entries.

# Root API key. When set, EVERY endpoint (except /health and /metrics)
# requires either this key or a managed key issued via /v1/keys, sent as
# `xi-api-key: <key>` or `Authorization: Bearer <key>`.
# The root key passes all scopes including key management.
# Leave empty to run the service fully open (bare local dev / loadtest).
# Generate one:  python -c "import secrets; print('gvt_root_' + secrets.token_hex(24))"
TTS_API_KEY=

# Optional overrides (defaults in service/config.py):
# TTS_WORKERS=2
# TTS_QUEUE_MAX=32
# TTS_TORCH_THREADS=4
# TTS_HOST=127.0.0.1
# TTS_PORT=8080
